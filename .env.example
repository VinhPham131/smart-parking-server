# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=smart_parking_db

# JWT
JWT_SECRET=your_jwt_secret_key

# Mail
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_mailtrap_user
EMAIL_PASSWORD=your_mailtrap_password
EMAIL_FROM=smartparking@gmail.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Redis cache
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL_SECONDS=60
CACHE_TTL_MY_VEHICLES_SECONDS=120
CACHE_TTL_PARKING_AREAS_SECONDS=300
CACHE_TTL_USER_PROFILE_SECONDS=300
CACHE_TTL_LIST_SECONDS=120

# OCR service
OCR_SERVICE_URL=http://localhost:8000
OCR_SERVICE_TIMEOUT_MS=30000
OCR_PLATE_VERIFY_ENABLED=true
